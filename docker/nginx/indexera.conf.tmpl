# Nginx Configuration for Indexera
#
# Serves the application via Nginx with PHP-FPM.
# Includes security hardening and proper routing for the PageMill Router.
#
# - Document root: /app/public
# - PHP-FPM via Unix socket
# - Denies access to hidden files and sensitive directories
# - Falls back to index.php for all non-existent paths (PageMill Router)

server {
    listen 80 default_server;
    listen [::]:80 default_server;

    server_name _;
    root /app/public;
    index index.php;

    # Logging
    access_log {{ default .Env.NGINX_ACCESS_LOG "/var/log/nginx/indexera-access.log" }};
    error_log {{ default .Env.NGINX_ERROR_LOG "/var/log/nginx/indexera-error.log" }};

    # Security: Deny access to hidden files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Security: Deny access to sensitive directories
    location ~ ^/(vendor|tests|schema|src)/ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Security: Deny access to composer files
    location ~ ^/(composer\.(json|lock)|package\.json)$ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Main location block
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    # PHP-FPM configuration
    location ~ \.php$ {
        try_files $uri =404;

        fastcgi_pass unix:/var/run/php/php8.4-fpm.sock;
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;

        include fastcgi_params;

        fastcgi_read_timeout 300;
        fastcgi_send_timeout 300;
    }

    # Static assets with caching
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|webmanifest)$ {
        expires 30d;
        add_header Cache-Control "public";
        access_log off;
    }
}
