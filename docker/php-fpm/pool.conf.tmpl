; PHP-FPM Pool Configuration for Indexera
;
; Uses a Unix socket for communication with Nginx and runs as www-data.
;
; - Pool name: www
; - User/Group: www-data
; - Listen: Unix socket /var/run/php/php8.4-fpm.sock
; - Process manager: dynamic
; - Environment variables: preserved (clear_env = no) for DB_INDEXERA_* etc.

[www]

user = www-data
group = www-data

listen = /var/run/php/php8.4-fpm.sock

listen.owner = www-data
listen.group = www-data
listen.mode = 0660

pm = dynamic
pm.max_children = 20
pm.start_servers = 5
pm.min_spare_servers = 5
pm.max_spare_servers = 10
pm.max_requests = 500

; Logging
access.log = {{ .Env.PHP_ACCESS_LOG }}
php_admin_value[error_log] = {{ default .Env.PHP_ERROR_LOG "/var/log/php/$pool.error.log" }}
php_admin_flag[log_errors] = on

; Pass all host environment variables through to PHP
; Required for DB_INDEXERA_* and OAUTH_* config
clear_env = no

php_admin_value[upload_max_filesize] = 10M
php_admin_value[post_max_size] = 10M
php_admin_value[memory_limit] = 256M
php_admin_value[max_execution_time] = 300
